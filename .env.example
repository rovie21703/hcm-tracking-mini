# Frontend environment variables (copy to .env in project root)
# Vite exposes only variables prefixed with VITE_

# Optional: point the React app at the Express backend.
# Leave empty to talk to Firestore directly from the browser.
VITE_API_BASE=http://localhost:4000

# Optional: override Firebase web config via env vars instead of hardcoding
# in src/app/firebase/config.ts (useful for CI / Vercel deployments).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
